<!DOCTYPE html>
<html>

<head>

    <title>Nova Planta</title>

    <link
        rel="stylesheet"
        href="/css/style.css"
    >

</head>

<body>

<header>

    <h1>🌱 Nova Planta</h1>

    <a
        href="/dashboard"
        class="logout"
    >
        Voltar
    </a>

</header>

<div class="form-card">

    <form action="/plants/new" method="POST">

        <input
            class="input"
            type="text"
            name="apelido"
            placeholder="Apelido da planta"
            required
        >

        <input
            class="input"
            type="text"
            name="especie"
            placeholder="Espécie"
            required
        >

        <textarea
            class="input"
            name="descricao"
            placeholder="Descrição"
            rows="4"
        ></textarea>

        <label>
            Data de Plantio
        </label>

        <input
            class="input"
            type="date"
            name="dataPlantio"
        >

        <label>
            Última Rega
        </label>

        <input
            class="input"
            type="date"
            name="ultimaRega"
        >

        <button
            class="btn"
            type="submit"
        >
            🌿 Salvar Planta
        </button>

    </form>

</div>

</body>

</html>