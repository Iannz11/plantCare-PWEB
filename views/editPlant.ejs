<!DOCTYPE html>
<html>

<head>

    <title>Editar Planta</title>

    <link
        rel="stylesheet"
        href="/css/style.css"
    >

</head>

<body>

<header>

    <h1>✏️ Editar Planta</h1>

    <a
        href="/plants/<%= plant._id %>"
        class="logout"
    >
        Voltar
    </a>

</header>

<div class="form-card">

    <form
        action="/plants/edit/<%= plant._id %>"
        method="POST"
    >

        <input
            class="input"
            type="text"
            name="apelido"
            value="<%= plant.apelido %>"
            required
        >

        <input
            class="input"
            type="text"
            name="especie"
            value="<%= plant.especie %>"
            required
        >

        <textarea
            class="input"
            name="descricao"
            rows="4"
        ><%= plant.descricao %></textarea>

        <label>
            Data de Plantio
        </label>

        <input
            class="input"
            type="date"
            name="dataPlantio"
            value="<%= plant.dataPlantio ? plant.dataPlantio.toISOString().split('T')[0] : '' %>"
        >

        <label>
            Última Rega
        </label>

        <input
            class="input"
            type="date"
            name="ultimaRega"
            value="<%= plant.ultimaRega ? plant.ultimaRega.toISOString().split('T')[0] : '' %>"
        >

        <button
            class="btn"
            type="submit"
        >
            💾 Salvar Alterações
        </button>

    </form>

</div>

</body>

</html>